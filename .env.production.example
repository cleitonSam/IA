# ─────────────────────────────────────────────
#  Ambiente: PRODUCTION
#  Copie este arquivo para .env.production e preencha os valores
#  NUNCA commite o arquivo .env.production com dados reais!
# ─────────────────────────────────────────────

# Banco de dados — banco principal (ia_metricas)
DATABASE_URL=postgres://ia_user:SENHA@HOST:5432/ia_metricas?sslmode=disable

# Redis — database 0 (padrão de produção)
REDIS_URL=redis://default:SENHA@HOST:6379/0

# Chatwoot
CHATWOOT_URL=https://chat.fluxodigitaltech.com.br
CHATWOOT_TOKEN=SEU_TOKEN_CHATWOOT
CHATWOOT_WEBHOOK_SECRET=SEU_WEBHOOK_SECRET

# IA / LLM
OPENROUTER_API_KEY=sk-or-v1-SUA_CHAVE
OPENAI_API_KEY=sk-proj-SUA_CHAVE

# Google (Gemini TTS)
GOOGLE_API_KEY=SUA_CHAVE_GOOGLE

# Segurança — gere uma chave forte: openssl rand -hex 32
JWT_SECRET_KEY=GERE_COM_openssl_rand_hex_32

# App
APP_MODE=both
PORT=8000

# E-mail SMTP
SMTP_ADDRESS=smtp.hostinger.com
SMTP_PORT=587
SMTP_USERNAME=ti@fluxodigitaltech.com.br
SMTP_PASSWORD=SUA_SENHA_SMTP
MAILER_SENDER_EMAIL="Fluxo <ti@fluxodigitaltech.com.br>"

# Frontend
FRONTEND_URL=https://ia.fluxodigitaltech.com.br

# ImageKit CDN
IMAGEKIT_ID=ik_ia_bot
IMAGEKIT_PUBLIC_KEY=SUA_CHAVE_PUBLICA
IMAGEKIT_PRIVATE_KEY=SUA_CHAVE_PRIVADA

# Budget Tracker
USD_TO_BRL=5.70

# ─────────────────────────────────────────────
#  [AI-UPGRADE] Modelos LLM — Gemini 2.5 stack (abril 2026)
#  Pode sobrescrever aqui pra testar modelos sem mudar codigo.
# ─────────────────────────────────────────────
MODELO_LITE=google/gemini-2.5-flash-lite
MODELO_PADRAO=google/gemini-2.5-flash
MODELO_POTENTE=google/gemini-2.5-pro
MODELO_VISION=google/gemini-2.5-pro
MODELO_CLASSIFIER=google/gemini-2.5-flash-lite
# Override global (deixe vazio em operacao normal):
MODELO_PADRAO_OVERRIDE=

# ─────────────────────────────────────────────
#  [MKT-02] Alertas de escalacao (sentimento real-time)
# ─────────────────────────────────────────────
ALERT_WEBHOOK_URL=

# ─────────────────────────────────────────────
#  [MKT-04] Quotas de LLM por tenant
# ─────────────────────────────────────────────
LLM_QUOTA_DAILY_TOKENS_PER_EMPRESA=500000
LLM_QUOTA_MONTHLY_USD_PER_EMPRESA=50.0
LLM_QUOTA_RPM_PER_EMPRESA=60

# ─────────────────────────────────────────────
#  [MKT-05] Instagram DM
# ─────────────────────────────────────────────
INSTAGRAM_VERIFY_TOKEN=
INSTAGRAM_APP_SECRET=
INSTAGRAM_PAGE_ACCESS_TOKEN=
INSTAGRAM_GRAPH_VERSION=v21.0

# ─────────────────────────────────────────────
#  [MKT-06] Voice agent (Vapi ou Retell)
# ─────────────────────────────────────────────
VOICE_PROVIDER=disabled
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=
RETELL_API_KEY=
RETELL_AGENT_ID=
RETELL_PHONE_NUMBER=
VOICE_WEBHOOK_SECRET=

# ─────────────────────────────────────────────
#  [INF-10] Sentry
# ─────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ─────────────────────────────────────────────
#  [ARQ-02] Pool Postgres (ajuste conforme carga)
# ─────────────────────────────────────────────
DB_POOL_MIN=15
DB_POOL_MAX=60
