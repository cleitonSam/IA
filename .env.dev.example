# ─────────────────────────────────────────────
#  Ambiente: DEVELOPMENT
#  Copie este arquivo para .env.dev e preencha os valores
# ─────────────────────────────────────────────

# Banco de dados — use um banco separado para dev (ia_metricas_dev)
DATABASE_URL=postgres://ia_user:SENHA@HOST:5432/ia_metricas_dev?sslmode=disable

# Redis — usa database 2 para isolar do staging (db=1) e prod (db=0)
REDIS_URL=redis://default:SENHA@HOST:6379/2

# Chatwoot — pode usar a mesma instância ou uma de teste
CHATWOOT_URL=https://chat.fluxodigitaltech.com.br
CHATWOOT_TOKEN=SEU_TOKEN_CHATWOOT
CHATWOOT_WEBHOOK_SECRET=SEU_WEBHOOK_SECRET

# IA / LLM
OPENROUTER_API_KEY=sk-or-v1-SUA_CHAVE
OPENAI_API_KEY=sk-proj-SUA_CHAVE

# Google (Gemini TTS)
GOOGLE_API_KEY=SUA_CHAVE_GOOGLE

# Segurança — use uma chave diferente por ambiente!
JWT_SECRET_KEY=dev_secret_troque_por_uma_string_aleatoria_longa

# App
APP_MODE=both
PORT=8000

# E-mail SMTP
SMTP_ADDRESS=smtp.hostinger.com
SMTP_PORT=587
SMTP_USERNAME=ti@fluxodigitaltech.com.br
SMTP_PASSWORD=SUA_SENHA_SMTP
MAILER_SENDER_EMAIL="Antigravity IA DEV <ti@fluxodigitaltech.com.br>"

# Frontend (URL do nginx do dev)
FRONTEND_URL=http://dev.ia.fluxodigitaltech.com.br

# ImageKit CDN
IMAGEKIT_ID=ik_ia_bot
IMAGEKIT_PUBLIC_KEY=SUA_CHAVE_PUBLICA
IMAGEKIT_PRIVATE_KEY=SUA_CHAVE_PRIVADA

# Budget Tracker
USD_TO_BRL=5.70
